#!/usr/bin/python3
# Check which xpra package builds are present/missing in the local mirror
# of the build output repos (~/projects/repos/{lts,stable,beta}).
#
# usage:
#   list-missing [--all-minors] [--links]
#                                     generate a markdown status table for
#                                     all three channels, auto-detecting the
#                                     latest version available in each.
#                                     --all-minors lists every point release
#                                     instead of just the latest one per major.
#                                     --links turns each status icon into a
#                                     link to its download directory.
#   list-missing <channel> <version> list what is missing for one release
#                                     eg: list-missing lts 5.1.6

import glob
import os
import re
import sys

REPOS_ROOT = os.path.expanduser("~/projects/repos")
CHANNELS = ["lts", "stable", "beta"]

# kept in sync with repos/bin/update-rpm-repos.sh and repos/bin/update-deb-packages.py
RPM_DISTROS = ["Fedora", "CentOS", "almalinux", "rockylinux", "oraclelinux"]
RPM_ARCHES = ["x86_64", "aarch64", "riscv64"]

DEBIAN_DISTROS = "bullseye,bookworm,trixie,forky,sid".split(",")
UBUNTU_DISTROS = "bionic,focal,jammy,noble,resolute".split(",")
DEB_ARCHES = ["amd64", "arm64", "riscv64"]

MACOS_ARCHES = ["x86_64", "arm64"]
MSWINDOWS_ARCHES = ["x86_64", "aarch64"]

# filename patterns for the core "xpra" package only (not subpackages/debuginfo/dbgsym),
# used to discover which versions have actually been built in a given channel.
# both the regular ("full") and "Light" builds are recognised, since either one
# is evidence that a given version was released.
RPM_VER_RE = re.compile(r"^xpra-(\d[\d.]*)-")
DEB_VER_RE = re.compile(r"^xpra_(\d[\d.]*)(?:-r\d+)?-\d+_")
MACOS_VER_RE = re.compile(r"^Xpra-(?:Light-)?(?:x86_64|arm64)-(\d[\d.]*)-r\d+\.pkg$")
MSWIN_VER_RE = re.compile(r"^Xpra-(?:Light-)?(?:x86_64|aarch64)_(\d[\d.]*)-r\d+\.msi$")
VERSION_RES = (RPM_VER_RE, DEB_VER_RE, MACOS_VER_RE, MSWIN_VER_RE)

# Windows and macOS builds come in two flavours, distinguished by filename:
# the regular ("full") build, and the "Xpra-Light-..." build
BUILD_VARIANTS = ["full", "light"]


def variant_prefix(arch, variant):
    return "Xpra-Light-%s" % arch if variant == "light" else "Xpra-%s" % arch


def natural_key(s):
    return [int(t) if t.isdigit() else t for t in re.split(r"(\d+)", s)]


def version_key(v):
    return tuple(int(p) for p in v.split("."))


# debian/macOS use their own arch names on disk; display them using the same
# names as the rpm/MSWindows side for consistency
ARCH_DISPLAY = {"arm64": "aarch64", "amd64": "x86_64"}


def disp_arch(arch):
    return ARCH_DISPLAY.get(arch, arch)


# ---- presence checks (used by both modes) ----

def rpm_present(channel, distro, variant, arch, version):
    arch_dir = os.path.join(REPOS_ROOT, channel, distro, variant, arch)
    if not os.path.isdir(arch_dir):
        return None
    pattern = os.path.join(arch_dir, "xpra-%s-*.%s.rpm" % (version, arch))
    return bool(glob.glob(pattern))


def deb_present(channel, codename, arch, version):
    arch_dir = os.path.join(REPOS_ROOT, channel, codename, "main", "binary-%s" % arch)
    if not os.path.isdir(arch_dir):
        return None
    pattern = os.path.join(arch_dir, "xpra_%s-*_%s.deb" % (version, arch))
    return bool(glob.glob(pattern))


def macos_present(channel, arch, variant, version):
    arch_dir = os.path.join(REPOS_ROOT, channel, "MacOS", arch)
    if not os.path.isdir(arch_dir):
        return None
    pattern = os.path.join(arch_dir, "%s-%s-r*.pkg" % (variant_prefix(arch, variant), version))
    return bool(glob.glob(pattern))


def mswindows_present(channel, arch, variant, version):
    arch_dir = os.path.join(REPOS_ROOT, channel, "MSWindows", arch)
    if not os.path.isdir(arch_dir) or os.path.islink(arch_dir):
        return None
    pattern = os.path.join(arch_dir, "%s_%s-r*.msi" % (variant_prefix(arch, variant), version))
    return bool(glob.glob(pattern))


# ---- "list what's missing for one release" mode ----

def rpm_missing(channel, version):
    missing = []
    for distro in RPM_DISTROS:
        distro_dir = os.path.join(REPOS_ROOT, channel, distro)
        if not os.path.isdir(distro_dir):
            continue
        for release in sorted(os.listdir(distro_dir)):
            release_path = os.path.join(distro_dir, release)
            # skip the "8" -> "8.10" style latest-point-release symlinks,
            # the real versioned directory is checked directly
            if os.path.islink(release_path) or not os.path.isdir(release_path):
                continue
            for arch in RPM_ARCHES:
                if not os.path.isdir(os.path.join(release_path, arch)):
                    continue
                if not rpm_present(channel, distro, release, arch, version):
                    missing.append("%s/%s/%s" % (distro, release, disp_arch(arch)))
    return missing


def deb_missing(channel, version):
    missing = []
    for distro in DEBIAN_DISTROS + UBUNTU_DISTROS:
        main_dir = os.path.join(REPOS_ROOT, channel, distro, "main")
        if not os.path.isdir(main_dir):
            continue
        for arch in DEB_ARCHES:
            if not os.path.isdir(os.path.join(main_dir, "binary-%s" % arch)):
                continue
            if not deb_present(channel, distro, arch, version):
                missing.append("%s/%s" % (distro, disp_arch(arch)))
    return missing


def macos_missing(channel, version):
    missing = []
    for arch in MACOS_ARCHES:
        if not os.path.isdir(os.path.join(REPOS_ROOT, channel, "MacOS", arch)):
            continue
        for variant in BUILD_VARIANTS:
            if not macos_present(channel, arch, variant, version):
                missing.append("MacOS/%s/%s" % (variant, disp_arch(arch)))
    return missing


def mswindows_missing(channel, version):
    missing = []
    for arch in MSWINDOWS_ARCHES:
        arch_dir = os.path.join(REPOS_ROOT, channel, "MSWindows", arch)
        if not os.path.isdir(arch_dir) or os.path.islink(arch_dir):
            continue
        for variant in BUILD_VARIANTS:
            if not mswindows_present(channel, arch, variant, version):
                missing.append("MSWindows/%s/%s" % (variant, arch))
    return missing


def report_missing(channel, version):
    channel_dir = os.path.join(REPOS_ROOT, channel)
    if not os.path.isdir(channel_dir):
        sys.stderr.write("channel directory not found: %s\n" % channel_dir)
        sys.exit(1)

    categories = [
        ("rpm", rpm_missing(channel, version)),
        ("deb", deb_missing(channel, version)),
        ("MacOS", macos_missing(channel, version)),
        ("MSWindows", mswindows_missing(channel, version)),
    ]
    total = sum(len(items) for _, items in categories)
    if total == 0:
        print("%s %s: all builds present" % (channel, version))
        return
    print("%s %s: %i missing build(s)" % (channel, version, total))
    for category, items in categories:
        if items:
            print("\n%s:" % category)
            for item in items:
                print("  %s" % item)


# ---- "markdown status table, auto-detect latest" mode ----

def scan_versions(channel):
    versions = set()
    channel_dir = os.path.join(REPOS_ROOT, channel)
    for root, dirs, files in os.walk(channel_dir):
        # don't follow the "8" -> "8.10" / "arm64" -> "aarch64" style symlinks,
        # they would just duplicate work
        dirs[:] = [d for d in dirs if not os.path.islink(os.path.join(root, d))]
        for f in files:
            for regex in VERSION_RES:
                m = regex.match(f)
                if m:
                    versions.add(m.group(1))
                    break
    return versions


def latest_version(channel):
    versions = scan_versions(channel)
    if not versions:
        return None
    return max(versions, key=version_key)


MINOR_RELEASE_RE = re.compile(r"^(\d+)\.(\d+)$")


def latest_minor_only(targets):
    # for variants that look like "X.Y" (eg RHEL-style point releases: 8.8, 8.9,
    # 8.10), only keep the highest Y for a given (distro, X, arch) group.
    # variants that don't match this shape (eg "43", "stream9", "10-kitten")
    # are passed through unchanged, since they aren't a run of point releases.
    best = {}  # (distro, major, arch) -> (minor, variant)
    passthrough = set()
    for distro, variant, arch in targets:
        m = MINOR_RELEASE_RE.match(variant)
        if not m:
            passthrough.add((distro, variant, arch))
            continue
        major, minor = int(m.group(1)), int(m.group(2))
        key = (distro, major, arch)
        if key not in best or minor > best[key][0]:
            best[key] = (minor, variant)
    result = passthrough
    for (distro, _major, arch), (_minor, variant) in best.items():
        result.add((distro, variant, arch))
    return result


def discover_rpm_targets(all_minors=False):
    targets = set()
    for channel in CHANNELS:
        for distro in RPM_DISTROS:
            distro_dir = os.path.join(REPOS_ROOT, channel, distro)
            if not os.path.isdir(distro_dir):
                continue
            for release in os.listdir(distro_dir):
                release_path = os.path.join(distro_dir, release)
                if os.path.islink(release_path) or not os.path.isdir(release_path):
                    continue
                for arch in RPM_ARCHES:
                    if os.path.isdir(os.path.join(release_path, arch)):
                        targets.add((distro, release, arch))
    if not all_minors:
        targets = latest_minor_only(targets)
    return targets


def discover_deb_targets():
    targets = set()
    for channel in CHANNELS:
        for family, codenames in (("Debian", DEBIAN_DISTROS), ("Ubuntu", UBUNTU_DISTROS)):
            for codename in codenames:
                main_dir = os.path.join(REPOS_ROOT, channel, codename, "main")
                if not os.path.isdir(main_dir):
                    continue
                for arch in DEB_ARCHES:
                    if os.path.isdir(os.path.join(main_dir, "binary-%s" % arch)):
                        targets.add((family, codename, arch))
    return targets


def discover_macos_targets():
    targets = set()
    for channel in CHANNELS:
        for arch in MACOS_ARCHES:
            arch_dir = os.path.join(REPOS_ROOT, channel, "MacOS", arch)
            if os.path.isdir(arch_dir) and not os.path.islink(arch_dir):
                for variant in BUILD_VARIANTS:
                    targets.add(("macOS", variant, arch))
    return targets


def discover_mswindows_targets():
    targets = set()
    for channel in CHANNELS:
        for arch in MSWINDOWS_ARCHES:
            arch_dir = os.path.join(REPOS_ROOT, channel, "MSWindows", arch)
            if os.path.isdir(arch_dir) and not os.path.islink(arch_dir):
                for variant in BUILD_VARIANTS:
                    targets.add(("Windows", variant, arch))
    return targets


GREEN = "\U0001F7E2"
RED = "\U0001F534"
NA = "⚪"

BASE_URL = "https://xpra.org"


def status_icon(present):
    if present is None:
        return NA
    return GREEN if present else RED


def cell_markup(present, channel, path_parts, links):
    icon = status_icon(present)
    if not links or present is None:
        return icon
    url = "%s/%s/%s/" % (BASE_URL, channel, "/".join(path_parts))
    return "[%s](%s)" % (icon, url)


def print_table(all_minors=False, links=False):
    latest = {channel: latest_version(channel) for channel in CHANNELS}

    # rows: (distro, variant, display_arch, path_parts, cells)
    # path_parts is the on-disk path (relative to the channel dir) that was
    # checked, reused to build the download directory URL when --links is set
    rows = []
    for distro, variant, arch in discover_rpm_targets(all_minors=all_minors):
        cells = [
            rpm_present(channel, distro, variant, arch, latest[channel]) if latest[channel] else None
            for channel in CHANNELS
        ]
        rows.append((distro, variant, arch, [distro, variant, arch], cells))
    for family, codename, arch in discover_deb_targets():
        cells = [
            deb_present(channel, codename, arch, latest[channel]) if latest[channel] else None
            for channel in CHANNELS
        ]
        path_parts = [codename, "main", "binary-%s" % arch]
        rows.append((family, codename, disp_arch(arch), path_parts, cells))
    for distro, variant, arch in discover_macos_targets():
        cells = [
            macos_present(channel, arch, variant, latest[channel]) if latest[channel] else None
            for channel in CHANNELS
        ]
        rows.append((distro, variant, disp_arch(arch), ["MacOS", arch], cells))
    for distro, variant, arch in discover_mswindows_targets():
        cells = [
            mswindows_present(channel, arch, variant, latest[channel]) if latest[channel] else None
            for channel in CHANNELS
        ]
        rows.append((distro, variant, arch, ["MSWindows", arch], cells))

    rows.sort(key=lambda r: (r[0], natural_key(r[1]), r[2]))

    headers = ["distro", "variant", "arch"] + [
        "%s (%s)" % (channel, latest[channel] or "?") for channel in CHANNELS
    ]
    print("| " + " | ".join(headers) + " |")
    print("|" + "|".join(["---"] * len(headers)) + "|")
    for distro, variant, arch, path_parts, cells in rows:
        cell_str = " | ".join(
            cell_markup(c, channel, path_parts, links) for channel, c in zip(CHANNELS, cells)
        )
        print("| %s | %s | %s | %s |" % (distro, variant, arch, cell_str))


def main():
    args = sys.argv[1:]
    all_minors = "--all-minors" in args
    links = "--links" in args
    args = [a for a in args if a not in ("--all-minors", "--links")]

    if len(args) == 0:
        print_table(all_minors=all_minors, links=links)
    elif len(args) == 2:
        report_missing(args[0], args[1])
    else:
        sys.stderr.write("usage: %s [--all-minors] [--links]    (markdown status table)\n" % sys.argv[0])
        sys.stderr.write("       %s <beta|stable|lts> <version>\n" % sys.argv[0])
        sys.exit(1)


if __name__ == "__main__":
    main()
