#!/usr/bin/python3
# Show which xpra package builds are present in the local mirror of the
# build output repos (~/projects/repos/{lts,stable,beta}), as a markdown
# status table for one channel. The version checked is auto-detected as the
# latest version found in that channel's mirror.
#
# usage:
#   list-missing <beta|stable|lts> [--all-minors] [--links]
#     --all-minors  list every point release instead of just the latest one
#                   per major version (eg: rockylinux 8.8, 8.9, 8.10, ...)
#     --links       turn each status icon into a link to its download
#                   directory on xpra.org
#
# eg: list-missing lts

import glob
import os
import re
import sys

REPOS_ROOT = os.path.expanduser("~/projects/repos")
CHANNELS = ["lts", "stable", "beta"]
ARCHES = ["x86_64", "aarch64", "riscv64"]

# kept in sync with repos/bin/update-rpm-repos.sh and repos/bin/update-deb-packages.py
RPM_DISTROS = ["Fedora", "CentOS", "almalinux", "rockylinux", "oraclelinux"]
# canonical arch -> on-disk arch name, or None if that combination doesn't exist
RPM_ARCH_MAP = {"x86_64": "x86_64", "aarch64": "aarch64", "riscv64": "riscv64"}

DEBIAN_DISTROS = "bullseye,bookworm,trixie,forky,sid".split(",")
UBUNTU_DISTROS = "bionic,focal,jammy,noble,resolute".split(",")
DEB_ARCH_MAP = {"x86_64": "amd64", "aarch64": "arm64", "riscv64": "riscv64"}

MACOS_ARCH_MAP = {"x86_64": "x86_64", "aarch64": "arm64", "riscv64": None}
MSWINDOWS_ARCH_MAP = {"x86_64": "x86_64", "aarch64": "aarch64", "riscv64": None}

# Windows and macOS builds come in two flavours, distinguished by filename:
# the regular ("full") build, and the "Xpra-Light-..." build
BUILD_VARIANTS = ["full", "light"]

# filename patterns for the core "xpra" package only (not subpackages/debuginfo/dbgsym),
# used to discover which versions have actually been built in a given channel.
# both the regular ("full") and "Light" builds are recognised, since either one
# is evidence that a given version was released.
RPM_VER_RE = re.compile(r"^xpra-(\d[\d.]*)-")
DEB_VER_RE = re.compile(r"^xpra_(\d[\d.]*)(?:-r\d+)?-\d+_")
MACOS_VER_RE = re.compile(r"^Xpra-(?:Light-)?(?:x86_64|arm64)-(\d[\d.]*)-r\d+\.pkg$")
MSWIN_VER_RE = re.compile(r"^Xpra-(?:Light-)?(?:x86_64|aarch64)_(\d[\d.]*)-r\d+\.msi$")
VERSION_RES = (RPM_VER_RE, DEB_VER_RE, MACOS_VER_RE, MSWIN_VER_RE)

MINOR_RELEASE_RE = re.compile(r"^(\d+)\.(\d+)$")

GREEN = "\U0001F7E2"
RED = "\U0001F534"
NA = "⚪"
BASE_URL = "https://xpra.org"


def natural_key(s):
    return [int(t) if t.isdigit() else t for t in re.split(r"(\d+)", s)]


def version_key(v):
    return tuple(int(p) for p in v.split("."))


def variant_prefix(arch, variant):
    return "Xpra-Light-%s" % arch if variant == "light" else "Xpra-%s" % arch


# ---- presence checks, keyed by the on-disk arch name ----

def rpm_present(channel, distro, variant, arch, version):
    arch_dir = os.path.join(REPOS_ROOT, channel, distro, variant, arch)
    if not os.path.isdir(arch_dir):
        return None
    pattern = os.path.join(arch_dir, "xpra-%s-*.%s.rpm" % (version, arch))
    return bool(glob.glob(pattern))


def deb_present(channel, codename, arch, version):
    arch_dir = os.path.join(REPOS_ROOT, channel, codename, "main", "binary-%s" % arch)
    if not os.path.isdir(arch_dir):
        return None
    pattern = os.path.join(arch_dir, "xpra_%s-*_%s.deb" % (version, arch))
    return bool(glob.glob(pattern))


def macos_present(channel, arch, variant, version):
    arch_dir = os.path.join(REPOS_ROOT, channel, "MacOS", arch)
    if not os.path.isdir(arch_dir):
        return None
    pattern = os.path.join(arch_dir, "%s-%s-r*.pkg" % (variant_prefix(arch, variant), version))
    return bool(glob.glob(pattern))


def mswindows_present(channel, arch, variant, version):
    arch_dir = os.path.join(REPOS_ROOT, channel, "MSWindows", arch)
    if not os.path.isdir(arch_dir) or os.path.islink(arch_dir):
        return None
    pattern = os.path.join(arch_dir, "%s_%s-r*.msi" % (variant_prefix(arch, variant), version))
    return bool(glob.glob(pattern))


# ---- version auto-detection ----

def scan_versions(channel):
    versions = set()
    channel_dir = os.path.join(REPOS_ROOT, channel)
    for root, dirs, files in os.walk(channel_dir):
        # don't follow the "8" -> "8.10" / "arm64" -> "aarch64" style symlinks,
        # they would just duplicate work
        dirs[:] = [d for d in dirs if not os.path.islink(os.path.join(root, d))]
        for f in files:
            for regex in VERSION_RES:
                m = regex.match(f)
                if m:
                    versions.add(m.group(1))
                    break
    return versions


def latest_version(channel):
    versions = scan_versions(channel)
    if not versions:
        return None
    return max(versions, key=version_key)


# ---- row discovery (distro/variant only, arch becomes a column) ----

def latest_minor_only(rows):
    # for variants that look like "X.Y" (eg RHEL-style point releases: 8.8, 8.9,
    # 8.10), only keep the highest Y for a given (distro, X) group. variants
    # that don't match this shape (eg "43", "stream9", "10-kitten") are passed
    # through unchanged, since they aren't a run of point releases.
    best = {}  # (distro, major) -> (minor, variant)
    passthrough = set()
    for distro, variant in rows:
        m = MINOR_RELEASE_RE.match(variant)
        if not m:
            passthrough.add((distro, variant))
            continue
        major, minor = int(m.group(1)), int(m.group(2))
        key = (distro, major)
        if key not in best or minor > best[key][0]:
            best[key] = (minor, variant)
    result = passthrough
    for (distro, _major), (_minor, variant) in best.items():
        result.add((distro, variant))
    return result


def discover_rpm_rows(channel, all_minors):
    rows = set()
    for distro in RPM_DISTROS:
        distro_dir = os.path.join(REPOS_ROOT, channel, distro)
        if not os.path.isdir(distro_dir):
            continue
        for release in os.listdir(distro_dir):
            release_path = os.path.join(distro_dir, release)
            # skip the "8" -> "8.10" style latest-point-release symlinks,
            # the real versioned directory is checked directly
            if os.path.islink(release_path) or not os.path.isdir(release_path):
                continue
            rows.add((distro, release))
    if not all_minors:
        rows = latest_minor_only(rows)
    return rows


def discover_deb_rows(channel):
    rows = set()
    for family, codenames in (("Debian", DEBIAN_DISTROS), ("Ubuntu", UBUNTU_DISTROS)):
        for codename in codenames:
            if os.path.isdir(os.path.join(REPOS_ROOT, channel, codename, "main")):
                rows.add((family, codename))
    return rows


def discover_macos_rows(channel):
    rows = set()
    for arch in MACOS_ARCH_MAP.values():
        if arch and os.path.isdir(os.path.join(REPOS_ROOT, channel, "MacOS", arch)):
            for variant in BUILD_VARIANTS:
                rows.add(("macOS", variant))
    return rows


def discover_mswindows_rows(channel):
    rows = set()
    for arch in MSWINDOWS_ARCH_MAP.values():
        arch_dir = os.path.join(REPOS_ROOT, channel, "MSWindows", arch) if arch else None
        if arch_dir and os.path.isdir(arch_dir) and not os.path.islink(arch_dir):
            for variant in BUILD_VARIANTS:
                rows.add(("Windows", variant))
    return rows


def status_icon(present):
    if present is None:
        return NA
    return GREEN if present else RED


def cell_markup(present, channel, path_parts, links):
    icon = status_icon(present)
    if not links or present is None:
        return icon
    return dir_link(icon, channel, path_parts)


def dir_link(text, channel, path_parts):
    url = "%s/%s/%s/" % (BASE_URL, channel, "/".join(path_parts))
    return "[%s](%s)" % (text, url)


def label_markup(text, channel, path_parts, links):
    if not links or not path_parts:
        return text
    return dir_link(text, channel, path_parts)


def print_table(channel, all_minors=False, links=False):
    version = latest_version(channel)

    # table_rows: (distro, distro_path_parts, variant, variant_path_parts,
    #              {canonical_arch: (present, path_parts)})
    table_rows = []

    for distro, variant in discover_rpm_rows(channel, all_minors):
        arch_cells = {}
        for arch, disk_arch in RPM_ARCH_MAP.items():
            present = rpm_present(channel, distro, variant, disk_arch, version) if version and disk_arch else None
            arch_cells[arch] = (present, [distro, variant, disk_arch])
        table_rows.append((distro, [distro], variant, [distro, variant], arch_cells))

    for family, codename in discover_deb_rows(channel):
        arch_cells = {}
        for arch, disk_arch in DEB_ARCH_MAP.items():
            present = deb_present(channel, codename, disk_arch, version) if version and disk_arch else None
            arch_cells[arch] = (present, [codename, "main", "binary-%s" % disk_arch])
        # "Debian"/"Ubuntu" is just our own grouping label, not a real directory
        table_rows.append((family, None, codename, [codename], arch_cells))

    for distro, variant in discover_macos_rows(channel):
        arch_cells = {}
        for arch, disk_arch in MACOS_ARCH_MAP.items():
            present = macos_present(channel, disk_arch, variant, version) if version and disk_arch else None
            arch_cells[arch] = (present, ["MacOS", disk_arch] if disk_arch else None)
        # "full"/"light" share the same directory, there is no variant-specific path
        table_rows.append((distro, ["MacOS"], variant, None, arch_cells))

    for distro, variant in discover_mswindows_rows(channel):
        arch_cells = {}
        for arch, disk_arch in MSWINDOWS_ARCH_MAP.items():
            present = mswindows_present(channel, disk_arch, variant, version) if version and disk_arch else None
            arch_cells[arch] = (present, ["MSWindows", disk_arch] if disk_arch else None)
        table_rows.append((distro, ["MSWindows"], variant, None, arch_cells))

    table_rows.sort(key=lambda r: (r[0], natural_key(r[2])))

    print("%s: %s" % (channel, version or "no version found"))
    print()
    headers = ["distro", "variant"] + ARCHES
    print("| " + " | ".join(headers) + " |")
    print("|" + "|".join(["---"] * len(headers)) + "|")
    for distro, distro_path, variant, variant_path, arch_cells in table_rows:
        cells = []
        for arch in ARCHES:
            present, path_parts = arch_cells[arch]
            cells.append(cell_markup(present, channel, path_parts, links) if path_parts else NA)
        distro_cell = label_markup(distro, channel, distro_path, links)
        variant_cell = label_markup(variant, channel, variant_path, links)
        print("| %s | %s | %s |" % (distro_cell, variant_cell, " | ".join(cells)))


def main():
    args = sys.argv[1:]
    all_minors = "--all-minors" in args
    links = "--links" in args
    args = [a for a in args if a not in ("--all-minors", "--links")]

    if len(args) != 1 or args[0] not in CHANNELS:
        sys.stderr.write("usage: %s <beta|stable|lts> [--all-minors] [--links]\n" % sys.argv[0])
        sys.exit(1)

    print_table(args[0], all_minors=all_minors, links=links)


if __name__ == "__main__":
    main()
